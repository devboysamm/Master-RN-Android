# Admin panel build config (Vite reads VITE_* at build time).
# Production API base URL (the locked new domain):
VITE_API_BASE_URL=https://api.masterreactnative.me
# For local development against a backend on your machine, instead use:
# VITE_API_BASE_URL=http://localhost:5000
VITE_API_TIMEOUT_MS=20000
VITE_API_RETRIES=2
